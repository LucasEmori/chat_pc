# Renomeie para .env e preencha com ao menos uma chave.
# ATENÇÃO: a chave NVIDIA DEVE começar com "nvapi-" (uma vez, não duplicado).
# O modelo NVIDIA DEVE suportar structured output (ex.: meta/llama-3.3-70b-instruct).
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Fallback OpenRouter (usado quando NVIDIA falha por limites/quota/erro).
# OpenRouter usa API compatível com OpenAI.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# LangSmith Tracing (auto-detectado por LangChain/LangGraph).
# LANGSMITH_TRACING=true ativa tracing de TODAS as chamadas LLM + graph.
# Crie API key em https://smith.langchain.com/settings
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=chat_pc_invoices
