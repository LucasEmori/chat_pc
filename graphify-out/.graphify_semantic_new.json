    {
      "id": "readme_md_validation_retry_mechanism",
      "label": "ValidationError retry mechanism (1x auto-retry, then HITL)",
      "file_type": "rationale",
      "source_file": "C:\\Projetos\\chat_pc\\README.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Outputs outside controlled vocabulary trigger ValidationError → automatic retry (1x) re-sending error to LLM; if persists, becomes duvida_pendente=True for HITL."
    },
